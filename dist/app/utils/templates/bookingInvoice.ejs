<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Tour Booking Invoice</title>
  </head>
  <body
    style="
      font-family: Arial, sans-serif;
      background: #f7f7f7;
      color: #333;
      margin: 0;
      padding: 20px;
    "
  >
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
      <tr>
        <td align="center">
          <table
            role="presentation"
            width="500"
            cellspacing="0"
            cellpadding="0"
            style="background: #fff; border-radius: 8px; padding: 30px"
          >
            <tr>
              <td>
                <h2>Hello <%= name %>,</h2>
                <p>
                  You have booked <strong><%= tourName%></strong> form our
                  PH-Tour
                </p>
                <p>Total guest <%= totalGuest%></p>
                <p>Total cost <%= totalCost%></p>
                <h3>Download invoice pdf <a href=""></a></h3>
                <p>Thank you for booking tour</p>
                <div style="margin-top: 30px; font-size: 12px; color: #888">
                  &copy; PH Tour Management. All rights reserved.
                </div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>